{
  "name": "agentic-sdlc-vscode",
  "displayName": "Agentic SDLC",
  "description": "Debug-first VS Code extension for Agentic SDLC runtime snapshots, diagnostics, and evidence capture.",
  "version": "1.0.1",
  "publisher": "PramodKumarVoola",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jarvis2021/agentic-sdlc-development.git"
  },
  "homepage": "https://github.com/Jarvis2021/agentic-sdlc-development",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "agentic",
    "sdlc",
    "debugging",
    "diagnostics",
    "trace",
    "mcp"
  ],
  "main": "./extension.js",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "agenticSdlc.refresh",
        "title": "Agentic SDLC: Refresh"
      },
      {
        "command": "agenticSdlc.captureCommandFailure",
        "title": "Agentic SDLC: Capture Command Failure"
      },
      {
        "command": "agenticSdlc.captureTestFailure",
        "title": "Agentic SDLC: Capture Test Failure"
      },
      {
        "command": "agenticSdlc.captureCiFailure",
        "title": "Agentic SDLC: Capture CI Failure"
      },
      {
        "command": "agenticSdlc.captureBrowserVerification",
        "title": "Agentic SDLC: Capture Browser Verification"
      },
      {
        "command": "agenticSdlc.showResumeSnapshot",
        "title": "Agentic SDLC: Show Resume Snapshot"
      },
      {
        "command": "agenticSdlc.openLatestTrace",
        "title": "Agentic SDLC: Open Latest Trace"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "agenticSdlcRuntime",
          "name": "Agentic SDLC Runtime"
        },
        {
          "id": "agenticSdlcDiagnostics",
          "name": "Agentic SDLC Diagnostics"
        }
      ]
    },
    "configuration": {
      "title": "Agentic SDLC",
      "properties": {
        "agenticSdlc.eventsLimit": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 100,
          "description": "Number of runtime events to show in the Runtime view."
        },
        "agenticSdlc.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Refresh the runtime and diagnostics views after capture commands complete."
        }
      }
    }
  },
  "scripts": {
    "package": "npx @vscode/vsce package",
    "publish:marketplace": "npx @vscode/vsce publish"
  },
  "dependencies": {
    "agentic-sdlc-development": "^1.0.0"
  },
  "files": [
    "LICENSE",
    "extension.js",
    "lib/**/*.js"
  ]
}
